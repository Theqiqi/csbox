{
  "version": 3,
  
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES"
      }
    },
    {
      "name": "msvc_base",
      "hidden": true,
      "inherits": "base",
      "architecture": { "value": "x64", "strategy": "external" },
      "toolset": { "value": "host=x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "MSVC"
        }
      }
    },
    {
      "name": "static-release",
      "displayName": "MSVC Static Release",
      "inherits": "msvc_base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
      }
    },
    {
      "name": "msvc_base_x86",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": "Win32",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x86-windows-static",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "MSVC32"
        }
      }
    },
    {
      "name": "msvc-release-x86",
      "displayName": "MSVC Release x86",
      "inherits": "msvc_base_x86",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
      }
    },
    {
      "name": "msvc-dynamic",
      "displayName": "MSVC Dynamic Debug",
      "inherits": "msvc_base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebugDLL"
      }
    }

  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "msvc-dynamic"
    },
    {
      "name": "release",
      "configurePreset": "static-release",
      "configuration": "Release"
    },
    {
      "name": "release-x86",
      "configurePreset": "msvc-release-x86",
      "configuration": "Release"
    }
  ]
}
